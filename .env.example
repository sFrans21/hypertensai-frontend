# URL dasar backend FastAPI. Frontend memanggil: ${NEXT_PUBLIC_API_URL}/api/v1/analyze
# Saat pengembangan lokal biasanya FastAPI berjalan di http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mode Demo (opsional). Set ke "true" HANYA untuk presentasi tanpa backend aktif.
# Jika "true", aplikasi menghasilkan hasil SIMULASI yang diberi label jelas "DATA SIMULASI".
# Biarkan kosong atau "false" untuk produksi.
NEXT_PUBLIC_DEMO_MODE=false
